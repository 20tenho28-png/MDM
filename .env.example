# IMAP credentials
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=sales@company.com
IMAP_PASSWORD=replace-me
IMAP_INBOX_FOLDER=INBOX
IMAP_SENT_FOLDER=Sent

# Polling
POLL_INTERVAL_SECONDS=60

# Database
DATABASE_URL=postgresql+asyncpg://mdm:mdm@localhost:5432/mdm

# Color thresholds (hours since last customer inbound)
AGE_YELLOW_HOURS=24
AGE_ORANGE_HOURS=48
AGE_RED_HOURS=72

# How long closed deals stay in the bottom strip
CLOSED_STRIP_DAYS=7

# Refresh interval for the TV wall (seconds)
WALL_REFRESH_SECONDS=30
